# Airtable — base portfolio
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=
# Airtable — base CRM AI (résolution des noms Architecte / Mandataire / Entreprise)
AIRTABLE_CRM_BASE_ID=
AIRTABLE_CRM_TABLE_NAME=

# WordPress
WP_BASE_URL=
WP_USER=
WP_APP_PASSWORD=
# Galeries « Portfolio Filter Gallery » des pages de pôle (optionnel — défauts
# codés en dur : DEV=4904, ENV=7826, STR=2461). À surcharger si recréées côté WP.
WP_PFG_GALLERY_DEV=
WP_PFG_GALLERY_ENV=
WP_PFG_GALLERY_STR=

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Mettre à "true" pour utiliser @sparticuz/chromium (déploiement AWS Lambda / Vercel)
USE_CHROMIUM_LAMBDA=
# Optionnel — chemin vers chrome.exe ou msedge.exe (auto-détecté sinon)
CHROME_EXECUTABLE_PATH=
